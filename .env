# Django Secret Key: IMPORTANT for security!
# Replace 'your-secret-key-here-make-it-long-and-random' with a long, random, and unique string.
# You can generate one using Python:
# # import random; import string; print(''.join(random.SystemRandom().choice(string.ascii_letters + string.digits + '!@#$%^&*(-_=+)' for _ in range(50)))
SECRET_KEY=django-insecure-example-long-random-string-for-testing-only-replace-me-in-production

# # Debug Mode: Set to True for development, False for production
DEBUG=True

# # OpenAI API Key: Required for advanced AI responses.
# # Leave empty (or as an empty string) if you don't have one right now.
# # The chatbot will use its rule-based fallback without this key.
OPENAI_API_KEY=

# # Database URL: For SQLite, this points to your database file.
DATABASE_URL=sqlite:///db.sqlite3

# .env file
# SECRET_KEY=your-secret-key-here-make-it-long-and-random
# DEBUG=True
